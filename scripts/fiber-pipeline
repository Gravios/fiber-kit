#!/usr/bin/env bash
# ============================================================================
# fiber-kit pipeline driver, one electrode group, stage-dispatched.
# Installed on PATH by `pip install fiber-kit` (setup.cfg [options] scripts).
#
# USAGE:
#   fiber-pipeline <elec>                        # whole pipeline, in canonical order
#   fiber-pipeline <elec> all                    # same
#   fiber-pipeline <elec> fiber-refine           # one stage
#   fiber-pipeline <elec> fiber-cpos fiber-link  # several (always run in canonical order)
#   fiber-pipeline -l | --list                   # list stages
#
# The electrode group is the FIRST positional argument.  (FK_ELEC is still honoured
# as a fallback when no leading group is given, for older invocations.)
#
# CONFIG (env-overridable; the installed script is not meant to be hand-edited):
#   FK_DIR    session directory                 (default: current directory)
#   FK_SESS   session name                      (default: basename of FK_DIR)
#   FK_ELEC   electrode group fallback          (used only if no leading <elec> arg)
#   plus the algorithm/warp knobs below (each FK_*-overridable).
# e.g.:  fiber-pipeline 5 fiber-refine
#        cd /data/.../sirotaA-jg-000005-20120312 && fiber-pipeline 5
#
# Each stage reads the previous stage's output, so a single-stage run assumes the
# upstream artefacts already exist.  Canonical order:
#   fiber-session -> fiber-realign -> fiber-refine -> fiber-peel -> fiber-cpos -> fiber-intrachunk -> fiber-link
#
# Correctness notes baked in (do not "fix"):
#   * fiber-session uses --fine-method for the algorithm (--method is the feature tag).
#   * fiber-realign runs as an IN-PLACE commit: NO --out-variant (it reads the INPUT .spk
#     from that variant, so --out-variant realign would seek .spk.realign.N and fail).
#   * fiber-cpos localizes from the RAW/standard .spk, never .spkD, and runs AFTER refine
#     on the refine clu so positions key to the clu the merge tools read.
#
# Warp knobs (group-delay / Omlor-Giese) require patches 0083-0086; they are passed only
# when non-empty, so the script still runs on a tree without them.  Empty = disabled.
# ============================================================================
set -euo pipefail

# ---------- optional YAML config (sets the FK_* knobs the block below reads) --------------
# fiber-kit.yaml is a FLAT <FK_KEY: value> mapping of tuning knobs.  Run `fiber-kit-init` to
# drop a template into the current directory, then edit it.  Precedence:
#     exported FK_* env var   >   $FK_CONFIG yaml   >   built-in default in the block below.
# Absent file => built-in defaults (identical to the pre-config behaviour).  An empty YAML value
# ("") means "use the built-in default".  $FK_CONFIG defaults to fiber-kit.yaml in the current
# working directory (where the pipeline is run); set FK_CONFIG to point elsewhere.
FK_CONFIG="${FK_CONFIG:-$PWD/fiber-kit.yaml}"
if [ -f "$FK_CONFIG" ]; then
    _cfg="$(python3 - "$FK_CONFIG" <<'PYCFG'
import sys, shlex
try:
    import yaml
except ImportError:
    sys.stderr.write("fiber-pipeline: PyYAML not installed; ignoring %s\n" % sys.argv[1]); sys.exit(0)
try:
    with open(sys.argv[1]) as fh:
        d = yaml.safe_load(fh) or {}
except Exception as e:
    sys.stderr.write("fiber-pipeline: cannot read %s: %s\n" % (sys.argv[1], e)); sys.exit(1)
if not isinstance(d, dict):
    sys.stderr.write("fiber-pipeline: %s is not a flat key:value mapping\n" % sys.argv[1]); sys.exit(1)
for k, v in d.items():
    if k == "pipeline":            # the optional embedded primary plan -- handled separately, not an FK_* knob
        continue
    if not (isinstance(k, str) and k.startswith("FK_") and k.replace("_", "").isalnum()):
        sys.stderr.write("fiber-pipeline: skipping non-FK_/odd key %r\n" % (k,)); continue
    if isinstance(v, bool):            v = "1" if v else "0"
    elif v is None:                    v = ""
    elif isinstance(v, (int, float, str)): v = str(v)
    else:
        sys.stderr.write("fiber-pipeline: skipping non-scalar %s\n" % k); continue
    # assign ONLY if the FK_* env var is UNSET, so an exported override (even empty) still wins;
    # shlex.quote keeps empty -> '' (a true empty string, not the literal two-char ''):
    print('if [ -z "${%s+x}" ]; then %s=%s; export %s; fi' % (k, k, shlex.quote(v), k))
PYCFG
)" || { echo "fiber-pipeline: failed to parse $FK_CONFIG" >&2; exit 1; }
    eval "$_cfg"
fi

# ===================== algorithm knobs (all env-overridable) ===========
CFIBER_Q="${FK_CFIBER_Q:-0.90}"          # 0079 fiber-session : within-fiber cfiber-null quantile (shape veto)
FOLD_OFF_THR="${FK_FOLD_OFF_THR:-0.22}"  # 0078 fiber-refine  : timing veto on the contaminant fold (0.20-0.25)
SPLIT_VAR_MULT="${FK_SPLIT_VAR_MULT:-1.5}" # 0081 fiber-refine : split only clusters w/ top-3 feat-var > x median
# fiber-intrachunk tuning now lives in the per-session <session>.yaml `fiber_kit.intrachunk` section
# (config.py IntrachunkConfig).  The pipeline passes `--profile recommended` (the tuned baseline);
# that block, an exported FK_INTRA_*/FK_ALIGN_*/FK_REFRAC_CEILING/FK_PRE_MERGE_COS/FK_CFIBER_* env
# var, or a direct --flag override it.  `fiber-kit-session-config` emits a starter block.
# fiber-refine: how to handle stale leftover per-spike files (.clu/.fet from a prior, differently-counted
# run) that a fresh dedup cannot subset.  quarantine (default) renames each aside as <file>.stalebkp and
# proceeds (re-runnable, non-destructive); error blocks; skip leaves them.  Legacy FK_DEDUP_STRICT: 1->error, 0->skip.
if [ -n "${FK_DEDUP_STALE:-}" ]; then DEDUP_STALE="$FK_DEDUP_STALE"
elif [ "${FK_DEDUP_STRICT:-}" = "1" ]; then DEDUP_STALE="error"
elif [ "${FK_DEDUP_STRICT:-}" = "0" ]; then DEDUP_STALE="skip"
else DEDUP_STALE="quarantine"; fi

# ===================== warp knobs 0083-0086 (empty = off) ==============
# 0086 fiber-refine recall: merge drift fragments cosine misses, when median-template group-delay
# (warp) AND amplitude-profile both agree.  g5: warp>=0.9 & amp>=0.7 recovered 323/395 such merges
# at >=0.976 precision, refractory-clean.  Aggressive -- calibrate vs fuller curation before production.
MERGE_WARP_RECALL="${FK_MERGE_WARP_RECALL:-}"     # empty = OFF (default).  The warp-recall path admits merges
                                                  #   BELOW the cosine floor (warp+amp coherent) -- that is drift-
                                                  #   fragment STITCHING and belongs to fiber-intrachunk, which has
                                                  #   the offset/depth/cfiber/refractory-ceiling precision gates.
                                                  #   In refine it over-merges (~2x extra sub-cosine edges) once
                                                  #   session over-clusters.  Set 0.9 only if curation shows refine
                                                  #   must reunite drift fragments locally.
MERGE_AMP_THR="${FK_MERGE_AMP_THR:-0.7}"           # amplitude-profile correlation floor for the recall path
MERGE_WARP_THR="${FK_MERGE_WARP_THR:-}"            # 0084 precision GATE on cosine-selected merges (empty=off)
MERGE_WARP_RESID_THR="${FK_MERGE_WARP_RESID_THR:-}" # single-channel warp-incongruity SUB-gate on the warp gate/recall (empty=off)
MERGE_WARP_RESID_THR_INT="${FK_MERGE_WARP_RESID_THR_INT:-}"  # cell-type-aware warp-resid gate: INTERNEURON threshold (empty=off)
MERGE_WARP_RESID_THR_PYR="${FK_MERGE_WARP_RESID_THR_PYR:-}"  # cell-type-aware warp-resid gate: PYRAMIDAL threshold (set both to enable)
# 0085 fiber-link warp co-gate: on g5 did NOT help (precision already saturated; per-chunk templates
# too noisy) -- off by default.  The linking win was relaxing the cosine prefilter (LINK_COS_THR).
LINK_WARP_THR="${FK_LINK_WARP_THR:-}"              # empty = off
LINK_WARP_AMP_THR="${FK_LINK_WARP_AMP_THR:-}"      # Omlor-Giese amplitude-profile floor (eq.10); empty = off
LINK_WARP_RESID_THR="${FK_LINK_WARP_RESID_THR:-}"  # single-channel warp-incongruity ceiling (samples); empty = off
LINK_COS_THR="${FK_LINK_COS_THR:-0.75}"            # 0.75 added 7 clean bundles vs the 0.85 default

# 0080 overlap-backbone standard-space co-gate (fiber-intrachunk --emit-units).  The boundary match
# runs on the stderiv spkD, which is near-blind to depth/amplitude; these co-gate each accepted seed
# on the RAW standard median template.  BACKBONE_WARP (group-delay coherence) is the extra warp gate.
BACKBONE_STD_COS="${FK_BACKBONE_STD_COS:-}"        # empty = stage default (0.75); 0 disables the cosine co-gate
BACKBONE_WARP="${FK_BACKBONE_WARP:-}"              # empty = off (warp co-gate)

# ===================== cfiber shape gate (affine-invariant) ============
# cfiber = rotation+scale+translation-invariant Fourier descriptor of each unit's complex channel-
# loop.  Drift-invariant by construction, so it complements/strengthens the (mutual-centre-dependent)
# cosine shape term.  Real-data (g5 180-210, split-half): cfiber AUC ~0.955 vs cosine ~0.964 overall,
# but marginally BETTER on the hard look-alike subset (cosine>0.85: 0.867 vs 0.861) -- the regime that
# matters; its advantage is expected to widen under real cross-chunk drift (untested here).
#   * intrachunk: cfiber REPLACES the cosine shape term (gate='cfiber'); threshold self-calibrates from
#     the per-fragment split-half null at INTRA_CFIBER_Q.  Set FK_INTRA_GATE=cosine to revert.
#   * link: cfiber is an additional CO-GATE (cosine AND cfiber); threshold self-calibrates at link time
#     from the overlap-backbone same-unit shape distances at LINK_CFIBER_Q.  Empty disables it.
LINK_CFIBER_Q="${FK_LINK_CFIBER_Q:-0.90}"          # empty = link cfiber co-gate off
LINK_AMP_GATE="${FK_LINK_AMP_GATE:-0}"             # absolute log-amplitude gate (natural log; 0 = off)
LINK_MIN_A="${FK_LINK_MIN_A:-0}"                   # absolute amplitude (A) floor on linkability, SEEDS included
                                                   #   (drops noise-floor A~1 fragments that weld into bundles); 0 = off
LINK_AMP_SPAN="${FK_LINK_AMP_SPAN:-0}"             # varbound bundler: max per-bundle logA span (natural log; 0 = off)

# ===================== over-split tuning (small-cluster regime) ========
# Goal: more, CLEANER clusters that separate subtle co-located pairs (footprint-ratio /
# sub-sample timing), for the over-split -> fiber-intrachunk re-merge strategy.  These lower
# the SIZE gates and sharpen alignment/features while leaving the STATISTICAL accept gates
# (dip test, BIC) largely intact -- so splits track real structure, not noise.
# STARTING POINTS from code-reading + reasoning, NOT a validated sweep: check resulting cluster
# count / purity and back off if over-fragmenting (raise REFINE_LARGE / DIP_MIN, lower DIP_ALPHA).
REFINE_LARGE="${FK_REFINE_LARGE:-150}"             # refine splits only clusters >= this (stock 800 skips
                                                   #   every 60-700-spike unit -> subtle pairs never split)
REFINE_MIN_GROUP="${FK_REFINE_MIN_GROUP:-30}"      # min spikes per split piece in refine (stock 40)
REFINE_DROP_MIN="${FK_REFINE_DROP_MIN:-5}"         # cluster-KEEP floor: a cluster below this is dropped to the
                                                   #   artifact bin each iteration.  Decoupled from MIN_GROUP (the
                                                   #   split-PIECE floor): at MIN_GROUP=30 refine discarded session's
                                                   #   small over-split fragments (8-30 spikes) wholesale.  5 keeps
                                                   #   real fragments for intrachunk to stitch, sheds only noise; 0 =
                                                   #   keep everything; set =MIN_GROUP for the old (lossy) behaviour.
REFINE_DEDUP="${FK_REFINE_DEDUP:-0}"               # 0 = NO spike dedup (default).  The sub-floor dedup pass drops
                                                   #   ~200-300 near-coincident sub-threshold duplicates, but it
                                                   #   re-indexes the spike list so the output clu no longer aligns
                                                   #   1:1 with the canonical .res -- which breaks round-tripping of
                                                   #   curated clu files.  1 (--dedup) re-enables the pass.
RKK_DELETE="${FK_RKK_DELETE:-1}"                   # 1 = rkk (CEM) culls sub-min-group sub-clusters during a
                                                   #   split; 0 (--no-rkk-delete) keeps small non-singular
                                                   #   pieces so the cascade stops shedding them to the
                                                   #   residual/artifact bin (use if artifact cluster is bloated)
REFINE_MERGE_MIN_SIM="${FK_REFINE_MERGE_MIN_SIM:-0.96}" # slacker merge-back (stock 0.92): keep over-splits
                                                   #   for fiber-intrachunk to adjudicate locally
REFINE_MERGE_BUDGET="${FK_REFINE_MERGE_BUDGET:-1.0}"   # merge-back [floor,window) refractory budget %: a merge
                                                   #   is allowed only if the merged unit stays <= this.
                                                   #   Lower (e.g. 0.5) = stricter = less aggressive merging;
                                                   #   pair with a higher MIN_SIM to keep distinct cells apart
AB_RECLAIM="${FK_REFINE_AB_RECLAIM:-0}"            # 1 = opt-in A/B contamination reclaim AFTER merge-back: move a host's
                                                   #   spikes into a clean DISTINCT donor when realigned shape clearly
                                                   #   prefers it (refractory-safe, reclaim-only, never spawns clusters).
                                                   #   Default 0 (off): the weak per-spike stderiv signal also moves clean
                                                   #   continuum-boundary spikes -- enable deliberately, not blindly.
AB_DISTINCT="${FK_REFINE_AB_DISTINCT:-0.93}"       # max host-residual/donor template corr to treat as two cells (>= = one)
AB_ABS="${FK_REFINE_AB_ABS:-0.50}"                 # absolute donor-shape floor a spike must reach (loose noise floor)
AB_MARGIN="${FK_REFINE_AB_MARGIN:-0.05}"           # donor must beat host by this to move (the precision/recall dial)
AB_MIN="${FK_REFINE_AB_MIN:-10}"                   # min spikes a donor reclaims from one host to commit the move
AB_SIGCAP="${FK_REFINE_AB_SIGCAP:-2000}"           # spikes used to estimate each cluster TEMPLATE (0=all); caps the
                                                   #   iterated-align bottleneck on whole-session merged clusters
AB_JOBS="${FK_REFINE_AB_JOBS:-1}"                  # worker threads for the reclaim template precompute (result-identical
                                                   #   speedup; helps whole-session, negligible in chunked mode)
REALIGN_AFTER="${FK_REALIGN_AFTER-fiber-refine fiber-peel fiber-intrachunk fiber-link}"  # stages after which to
                                                   #   re-roll each new group's spikes onto its unit template
                                                   #   (Klusters method).  Splits/merges across drift leave a
                                                   #   group's troughs spread; a per-unit realign re-tightens.
                                                   #   '' disables.  See FK_REALIGN_AFTER_MODE for how.
REALIGN_AFTER_MODE="${FK_REALIGN_AFTER_MODE:-shift-spk}"  # shift-spk = circular-roll the existing .spk (no .fil,
                                                   #   fast, validated) | reextract = re-read the .fil
REALIGN_FINAL_MODE="${FK_REALIGN_FINAL_MODE:-reextract}"  # mode for the LAST realign in the run (the one feeding
                                                   #   curation): reextract re-reads the .fil at the corrected
                                                   #   times -> cleanest final .spk/.fet (recovers samples drift
                                                   #   pushed out of the window).  Set = REALIGN_AFTER_MODE to skip.
DIP_DIM="${FK_DIP_DIM:-6}"                          # session dip-test PCA dims (stock 4): expose footprint PCs
DIP_ALPHA="${FK_DIP_ALPHA:-0.02}"                   # session dip p (stock 0.01): mildly more permissive; keep
                                                   #   statistical (>0.05 starts splitting on noise)
DIP_MIN="${FK_DIP_MIN:-30}"                         # session min cluster size to bisect (stock 40)
INCLUSION_K="${FK_INCLUSION_K:-2.5}"                # session per-fiber radius median+k*MAD (stock 3.0): purer cores
FEATURE_ALIGN="${FK_FEATURE_ALIGN:-xcorr}"          # sub-sample channel-summed align before featurize: the #1
                                                   #   lever for subtle shapes (misalignment blurs them together)
EBAND="${FK_EBAND:-0}"                              # session energy-band split (1=on): partition each ENERGY-
                                                   #   CONFOUNDED coarse fiber by log10-energy band, split per band,
                                                   #   relink by overlap-anchor -- surfaces shape sub-units the drift
                                                   #   axis masks (off by default; falls back to --fine-method per fiber)
EBAND_WIDTH="${FK_EBAND_WIDTH:-0.45}"              # band width (decades of energy)
EBAND_OVERLAP="${FK_EBAND_OVERLAP:-0.2}"           # band overlap (decades) for the overlap-anchor link
EBAND_CONFOUND="${FK_EBAND_CONFOUND:-0.4}"         # band a fiber only if PC1 R^2 vs log-energy >= this
EBAND_MIN_SPAN="${FK_EBAND_MIN_SPAN:-0.6}"         # band a fiber only if it spans >= this many decades
EBAND_LOW_ASSIGN="${FK_EBAND_LOW_ASSIGN:-0}"       # bottom fraction of the energy range made ASSIGNMENT-ONLY
                                                   #   (noise-floor angle): assign those spikes from the bands above

# ===================== stage gates (previously hardcoded, now exposed) ==
SESSION_FINE_METHOD="${FK_SESSION_FINE_METHOD:-rkk}"      # fiber-session per-fiber fine clusterer
SESSION_CHUNK_MIN="${FK_SESSION_CHUNK_MIN:-12}"           # fiber-session chunk length (min)
SESSION_RKK_DELETE="${FK_SESSION_RKK_DELETE:-0}"          # 0 = session OVER-clusters (keep small rkk sub-clusters;
                                                         #   the cull belongs to refine).  1 = cull like refine.
SESSION_MERGE_METHOD="${FK_SESSION_MERGE_METHOD:-sliding}" # coarse merge method (inert when MERGE_CORR=0)
SESSION_RESPLIT_PASSES="${FK_SESSION_RESPLIT_PASSES:-0}"          # iterative em_swap re-split + merge (0=off)
SESSION_COARSE_DR="${FK_SESSION_COARSE_DR:-0.15}"                   # coarse radial band half-width (lower = more, smaller coarse fibers)
SESSION_NO_WHITEN="${FK_SESSION_NO_WHITEN:-0}"                      # 1 = cluster in raw (unwhitened) feature space
SESSION_SEED_DENSITY="${FK_SESSION_SEED_DENSITY:-0.0}"               # >0 = density-preferential coarse seeding (0=uniform)
SESSION_RESEED_RESIDUAL_THR="${FK_SESSION_RESEED_RESIDUAL_THR:-0.0}"  # >0 = residual-gated reseed of welded fibers (0=off)
SESSION_RESEED_MIN_REDUCTION="${FK_SESSION_RESEED_MIN_REDUCTION:-0.05}"
SESSION_REFIT_ITERS="${FK_SESSION_REFIT_ITERS:-0}"                     # extra realign->refit->rejudge passes at inclusion (0=single)
if [ "$SESSION_NO_WHITEN" = "1" ]; then SESSION_WHITEN_FLAG="--no-whiten"; else SESSION_WHITEN_FLAG=""; fi
# fiber-stochastic (diagnostic; ensemble/consensus fibering over resampled draws — writes a fiber-space
# dump, does NOT alter the sort). All default-off / conservative.
STOCH_DRAWS="${FK_STOCH_DRAWS:-20}"                # resampled draws per chunk
STOCH_FRAC="${FK_STOCH_FRAC:-0.8}"                 # subsample fraction per draw (HIGH: low frac starves fibers)
STOCH_MATCH_CORR="${FK_STOCH_MATCH_CORR:-0.95}"    # template corr = "same fiber" across draws
STOCH_STABLE_FREQ="${FK_STOCH_STABLE_FREQ:-0.6}"   # recurrence fraction to call a fiber stable / freeze it
STOCH_PEEL_ROUNDS="${FK_STOCH_PEEL_ROUNDS:-0}"     # 0 = single pass; N = peel stable fibers, re-run on residual
STOCH_SEED="${FK_STOCH_SEED:-0}"
STOCH_LINK="${FK_STOCH_LINK:-average}"                # consensus grouping: average | complete | single
STOCH_WRITE_CLU="${FK_STOCH_WRITE_CLU:-0}"          # 1 = also write clu/clc/clp triplet for Klusters
if [ "$STOCH_WRITE_CLU" = "1" ]; then STOCH_CLU_FLAG="--stochastic-write-clu"; else STOCH_CLU_FLAG=""; fi
SESSION_RESPLIT_RESIDUAL_THR="${FK_SESSION_RESPLIT_RESIDUAL_THR:-0.08}"
SESSION_RESPLIT_TOPCH="${FK_SESSION_RESPLIT_TOPCH:-3}"
SESSION_RESPLIT_MIN_REDUCTION="${FK_SESSION_RESPLIT_MIN_REDUCTION:-0.20}"
SESSION_RESPLIT_MERGE_CORR="${FK_SESSION_RESPLIT_MERGE_CORR:-0.99}"
SESSION_RESPLIT_DETREND_EPISODE="${FK_SESSION_RESPLIT_DETREND_EPISODE:-0}"   # 1 = strip the episode-position axis
SESSION_RESPLIT_DETREND_WIN="${FK_SESSION_RESPLIT_DETREND_WIN:-90.0}"
SESSION_RESPLIT_DETREND_MIN_N="${FK_SESSION_RESPLIT_DETREND_MIN_N:-100}"
if [ "$SESSION_RESPLIT_DETREND_EPISODE" = "1" ]; then
    SESSION_DETREND_FLAG="--resplit-detrend-episode"
else
    SESSION_DETREND_FLAG=""
fi
SESSION_MERGE_CORR="${FK_SESSION_MERGE_CORR:-0}"          # 0 = NO session chunk-merge -> intrachunk does the
                                                         #   stitching (with its refractory gate).  0.90 = old
                                                         #   sliding merge (premature; the over-merge source).
SESSION_LINK="${FK_SESSION_LINK:-1}"                     # 1 = assemble a fiber's per-chunk fragments across chunks
                                                         #   (overlap-anchor; this is fiber SET-UP, not merging).  0 = --no-link
SESSION_CFIBER_GATE="${FK_SESSION_CFIBER_GATE:-1}"       # 1 = cfiber affine-invariant shape veto on coarse fragment merges
SESSION_DIPSPLIT="${FK_SESSION_DIPSPLIT:-1}"             # 1 = dip-bimodal split within fibers (over-cluster welds early)
SESSION_NO_NOISE="${FK_SESSION_NO_NOISE:-0}"           # 1 = sweep remaining noise into one undefined fiber (not the noise cluster)
SESSION_INCL_ASSIGN="${FK_SESSION_INCL_ASSIGN:-1}"      # 1 = keep spikes beyond the per-fiber inclusion radius (assign
                                                         #   them to that fiber) instead of dropping them to the unsorted
                                                         #   bin.  The radius (FK_INCLUSION_K) still defines the pure core
                                                         #   for geometry/templates; this just stops good high-amplitude
                                                         #   tail spikes (~6-7%) being lost to artifact.  0 = legacy drop.
REFINE_SPLIT_MIN_CORR="${FK_REFINE_SPLIT_MIN_CORR:-0.93}" # fiber-refine min split-piece corr to keep a split
REFINE_CHUNK_MINUTES="${FK_REFINE_CHUNK_MINUTES:-12}"     # fiber-refine chunk length (min)
REFINE_CHUNK_JOBS="${FK_REFINE_CHUNK_JOBS:-1}"           # parallel worker processes over chunks (drift-aware mode);
                                                         #   chunks are independent -> the main speedup for a chunked run
LINK_POS_THR="${FK_LINK_POS_THR:-1.5}"                    # fiber-link position gate
LINK_OFF_THR="${FK_LINK_OFF_THR:-1.0}"                    # fiber-link inter-channel offset gate
LINK_MAX_GAP="${FK_LINK_MAX_GAP:-2}"                      # fiber-link max chunk gap to bridge
# Cross-chunk under-link recovery (sub-sample realign + primary-channel-intersection cosine + energy-tangent
# guard).  OFF by default so an unedited config reproduces current link behaviour; the recommended operating
# point is align-lag 6, primary-amp-frac 0.30, and (once fiber-cpos emits per-fragment tangents) tan-thr 0.5.
LINK_ALIGN_LAG="${FK_LINK_ALIGN_LAG:-0}"                  # sub-sample re-registration half-window (0=off; 6 recommended)
LINK_ALIGN_UPSAMPLE="${FK_LINK_ALIGN_UPSAMPLE:-4}"        # cubic-spline upsample factor for the align-lag search
LINK_PRIMARY_AMP_FRAC="${FK_LINK_PRIMARY_AMP_FRAC:-0}"    # cosine over shared primary channels (0=off; 0.30 recommended)
LINK_TAN_THR="${FK_LINK_TAN_THR:-}"                       # energy-tangent (microfiber) co-gate (empty=off; 0.5 recommended)

# Template-DR candidate space.  1 = generate cross-chunk candidates as mutual-NN in template-DR feature
# space (computed on the fly from the per-fragment templates) instead of physical position
# (x0,y0,z0,logA).  Physical localization is degenerate on an octrode (z0 sign-folded, x0 near-constant),
# so position-NN proposes co-located-but-different units the cosine/cfiber co-gate then has to reject;
# DR-space proposes far cleaner candidates.  Default 0 (position-NN) so an unedited config reproduces
# current behaviour.
LINK_DR_CANDIDATES="${FK_LINK_DR_CANDIDATES:-0}"          # 1 = template-DR candidate space; 0 = position-NN
LINK_DR_K="${FK_LINK_DR_K:-10}"                           # template-DR dimensionality (~96% var on g5)
LINK_DR_THR="${FK_LINK_DR_THR:-}"                         # DR-space NN distance cap (empty = none; co-gates filter)

# 0023 fiber-link variance-bounded bundling (anti-chaining over-merge guard).  bundle=varbound seeds
# agglomeration from the highest-energy fragments and refuses a union that would spread a bundle's
# template variance past a single-neuron envelope (self-calibrated from the high-energy backbone at link
# time).  Targets the single-linkage over-merge where a high-cosine-but-distinct cross edge welds two
# units that never share a chunk (which the chunk-exclusivity guard cannot catch).  Default chunkexcl =
# the legacy cosine-ordered union-find, so nothing changes unless FK_LINK_BUNDLE is set to varbound.
LINK_BUNDLE="${FK_LINK_BUNDLE:-chunkexcl}"               # chunkexcl | varbound
LINK_VAR_SCALE="${FK_LINK_VAR_SCALE:-1.0}"               # varbound: dial the boundary (>1 merge more, <1 split more)
LINK_N_PC="${FK_LINK_N_PC:-12}"                          # varbound: template PCs defining the variance space
LINK_VAR_ALLOW="${FK_LINK_VAR_ALLOW:-}"                  # varbound: explicit boundary (empty = self-calibrate)

# ============================================================================
# 00xx fiber-peel: footprint + refractory confidence-ordered agglomeration of refine fragments.
#   Merges by amplitude-preserving footprint cosine, gated by the refractory cross-CCG veto
#   (complementary: footprint blocks the censoring fake-dip, refractory blocks footprint-similar
#   independents).  In-place relabel on the refine clu; cross-drift identity is left to fiber-link.
PEEL_FOOT_HI="${FK_PEEL_FOOT_HI:-0.97}"               # anneal start (strict; most-certain merges first)
PEEL_FOOT_LO="${FK_PEEL_FOOT_LO:-0.90}"               # anneal floor (best g5 result: ARI 0.46 -> 0.68 at 0.90)
PEEL_REFRAC_MS="${FK_PEEL_REFRAC_MS:-2.0}"            # refractory half-window (ms)
PEEL_REFRAC_THR="${FK_PEEL_REFRAC_THR:-0.3}"          # coincidence-ratio above which a pair is two cells (veto)
PEEL_REFRAC_MIN_EXP="${FK_PEEL_REFRAC_MIN_EXP:-5.0}"  # min expected coincidences for the veto to be powered
PEEL_REFRAC_CENSOR_MS="${FK_PEEL_REFRAC_CENSOR_MS:-0.0}"
PEEL_MIN_N="${FK_PEEL_MIN_N:-15}"                     # min spikes for a fragment to participate

STAGES=(fiber-session fiber-realign fiber-refine fiber-peel fiber-cpos fiber-intrachunk fiber-link)
CURATED_STAGES=(fiber-refit)                  # post-curation; recognized + plannable, but not part of `all`
ALT_STAGES=(fiber-backbone-link fiber-xcorr-merge fiber-stochastic)              # alternative linker (fiber-session fragments); plannable, not in `all`
KNOWN_STAGES=("${STAGES[@]}" "${CURATED_STAGES[@]}" "${ALT_STAGES[@]}")

# One-line summary per stage for -l/--list (indices align with STAGES, then CURATED_STAGES).
STAGE_SUMMARY=(
    "initial over-clustering -> deliberately over-split clean fragments (.clu.stderiv + .spk)"
    "Klusters-style per-spike realign, in-place commit (re-extract raw+stderiv from .fil)"
    "per-chunk split + fold gates + merge-back -> .refine"
    "footprint + refractory consolidation of the refine fragments (in-place relabel on .refine)"
    "per-chunk positions/templates on the refine clu, from the raw/standard .spk"
    "within-chunk precision merge (depth/shape/warp/offset/refractory) + emit .units.npz"
    "cross-chunk link across drift (union-find bundles) -> .refine_linked"
)
CURATED_SUMMARY=(
    "post-curation: rebuild the per-unit/per-chunk model from a curated .clu (no regrouping)"
)
ALT_SUMMARY=(
    "link fiber-session fragments on the invariant backbone (CI-overlap + warp veto); alt to intrachunk+link"
    "fuse near-identical clusters by Klusters roll-shift cosine + refractory veto; realign after each merge"
)

list_stages() {   # -l/--list : short per-stage summary
    local i
    echo "fiber-kit pipeline stages (canonical order; 'all' runs these in sequence):"
    for i in "${!STAGES[@]}"; do
        printf '  %-18s %s\n' "${STAGES[$i]}" "${STAGE_SUMMARY[$i]}"
    done
    echo "post-curation (recognized + plannable, NOT part of 'all'):"
    for i in "${!CURATED_STAGES[@]}"; do
        printf '  %-18s %s\n' "${CURATED_STAGES[$i]}" "${CURATED_SUMMARY[$i]}"
    done
    echo "alternative linkers (recognized + plannable, NOT part of 'all'):"
    for i in "${!ALT_STAGES[@]}"; do
        printf '  %-18s %s\n' "${ALT_STAGES[$i]}" "${ALT_SUMMARY[$i]}"
    done
}

# ----- modular step plumbing ------------------------------------------------
# A plan STEP may set these to retarget a stage's input/output clu stage tags, so a stage can be
# reordered or run more than once with different tags + params (see --plan / --emit-plan):
#   STEP_IN    input clu stage tag   ('' = the base over-cluster .clu.stderiv.<ELEC>)
#   STEP_OUT   output clu stage tag
#   STEP_CPOS  cpos stage tag to read (defaults to STEP_IN)
#   STEP_UNITS units stage tag for fiber-link (the .units.npz producer)
#   STEP_SPK   spk feature tag for fiber-cpos localization (raw; default 'standard')
#   STEP_ARGS  extra per-step flags, appended last so argparse last-wins overrides the knob defaults
# Unset => the canonical defaults baked into each stage below, so the default pipeline is unchanged.
_run() {   # run the command, or (dry-run) just print it
    if [ -n "${FK_DRYRUN:-}" ]; then printf '    + '; printf '%q ' "$@"; printf '\n'
    else "$@"; fi
}
clu_path() {   # $1 = clu stage tag ('' = base over-cluster)
    if [ -z "${1:-}" ]; then echo "$SESS.clu.stderiv.$ELEC"; else echo "$SESS.clu.stderiv.$ELEC.$1"; fi
}

# ------------------------------- stages -------------------------------------
fiber_session() {     # 1. initial over-clustering -> <SESS>.clu.stderiv.<ELEC> (+ .spk.stderiv)
    echo "== fiber-session  (-> $(clu_path "${STEP_OUT:-}")) =="
    local eband_args=()
    [ "$EBAND" = "1" ] && eband_args+=(--energy-band --eband-width "$EBAND_WIDTH" --eband-overlap "$EBAND_OVERLAP" --eband-confound "$EBAND_CONFOUND" --eband-min-span "$EBAND_MIN_SPAN" --eband-low-assign "$EBAND_LOW_ASSIGN")
    local sess_args=()
    [ "$SESSION_RKK_DELETE" = "0" ] && sess_args+=(--no-rkk-delete)        # over-cluster: don't cull (refine's job)
    [ "$SESSION_LINK" = "0" ]       && sess_args+=(--no-link)
    [ "$SESSION_CFIBER_GATE" = "1" ] && sess_args+=(--cfiber-gate --cfiber-q "$CFIBER_Q")
    [ "$SESSION_DIPSPLIT" = "1" ]   && sess_args+=(--dipsplit --dip-dim "$DIP_DIM" --dip-alpha "$DIP_ALPHA" --dip-min "$DIP_MIN")
    [ "$SESSION_INCL_ASSIGN" = "1" ] && sess_args+=(--incl-assign-rejected)   # keep inclusion-tail spikes in the sort
    [ "$SESSION_NO_NOISE" = "1" ]    && sess_args+=(--no-noise)               # remaining noise -> one undefined fiber
    _run fiber-session "$SESS" "$ELEC" \
        --method stderiv --fine-method "$SESSION_FINE_METHOD" \
        --chunk-min "$SESSION_CHUNK_MIN" --merge-method "$SESSION_MERGE_METHOD" --merge-corr "$SESSION_MERGE_CORR" \
        --coarse-dr "$SESSION_COARSE_DR" --seed-density "$SESSION_SEED_DENSITY" --reseed-residual-thr "$SESSION_RESEED_RESIDUAL_THR" --reseed-min-reduction "$SESSION_RESEED_MIN_REDUCTION" --refit-iters "$SESSION_REFIT_ITERS" $SESSION_WHITEN_FLAG --resplit-passes "$SESSION_RESPLIT_PASSES" --resplit-residual-thr "$SESSION_RESPLIT_RESIDUAL_THR" --resplit-topch "$SESSION_RESPLIT_TOPCH" --resplit-min-reduction "$SESSION_RESPLIT_MIN_REDUCTION" --resplit-merge-corr "$SESSION_RESPLIT_MERGE_CORR" \
        $SESSION_DETREND_FLAG --resplit-detrend-win "$SESSION_RESPLIT_DETREND_WIN" --resplit-detrend-min-n "$SESSION_RESPLIT_DETREND_MIN_N" \
        --feature-align "$FEATURE_ALIGN" --inclusion-k "$INCLUSION_K" \
        "${sess_args[@]+"${sess_args[@]}"}" "${eband_args[@]+"${eband_args[@]}"}" "${STEP_ARGS[@]+"${STEP_ARGS[@]}"}" "$@"
}

fiber_stochastic() {  # DIAGNOSTIC: ensemble/consensus fibering over resampled draws -> <SESS>.fiberens.<ELEC>.npz
    echo "== fiber-stochastic  (diagnostic -> $SESS.fiberens.$ELEC.npz) =="
    local st_args=()
    [ "${STOCH_VERBOSE:-0}" = "1" ] && st_args+=(--stochastic-verbose)
    _run fiber-stochastic "$SESS" "$ELEC" \
        --method stderiv --fine-method "$SESSION_FINE_METHOD" \
        --chunk-min "$SESSION_CHUNK_MIN" --merge-method "$SESSION_MERGE_METHOD" --merge-corr "$SESSION_MERGE_CORR" \
        --coarse-dr "$SESSION_COARSE_DR" --seed-density "$SESSION_SEED_DENSITY" --reseed-residual-thr "$SESSION_RESEED_RESIDUAL_THR" --reseed-min-reduction "$SESSION_RESEED_MIN_REDUCTION" --refit-iters "$SESSION_REFIT_ITERS" $SESSION_WHITEN_FLAG --resplit-passes "$SESSION_RESPLIT_PASSES" --resplit-residual-thr "$SESSION_RESPLIT_RESIDUAL_THR" --resplit-topch "$SESSION_RESPLIT_TOPCH" --resplit-min-reduction "$SESSION_RESPLIT_MIN_REDUCTION" --resplit-merge-corr "$SESSION_RESPLIT_MERGE_CORR" \
        --feature-align "$FEATURE_ALIGN" --inclusion-k "$INCLUSION_K" \
        --stochastic --stochastic-draws "$STOCH_DRAWS" --stochastic-frac "$STOCH_FRAC" \
        --stochastic-match-corr "$STOCH_MATCH_CORR" --stochastic-stable-freq "$STOCH_STABLE_FREQ" \
        --stochastic-peel-rounds "$STOCH_PEEL_ROUNDS" --stochastic-link "$STOCH_LINK" $STOCH_CLU_FLAG --stochastic-seed "$STOCH_SEED" \
        "${st_args[@]+"${st_args[@]}"}" "${STEP_ARGS[@]+"${STEP_ARGS[@]}"}" "$@"
}

fiber_realign() {     # 2. Klusters-style per-spike align, in-place commit (re-extract raw+stderiv from .fil)
    echo "== fiber-realign  (in-place on $(clu_path "${STEP_IN:-}")) =="
    _run fiber-realign "$SESS" "$ELEC" \
        --clu "$(clu_path "${STEP_IN:-}")" \
        --align-method klusters --reextract --refeaturize \
        --variants standard,stderiv "${STEP_ARGS[@]+"${STEP_ARGS[@]}"}" "$@"
}

stage_out_tag() {     # default output clu tag of a stage in canonical 'all' order (matches each stage's STEP_OUT default)
    case "$1" in
        fiber-refine)     echo "refine" ;;
        fiber-peel)       echo "refine" ;;            # peel relabels .refine in place
        fiber-intrachunk) echo "refine_intrachunk" ;;
        fiber-link)       echo "refine_linked" ;;
        *)                echo "" ;;
    esac
}

realign_after() {     # post-step Klusters re-roll: align each just-updated group's spikes to its unit template, in place
    local tag="$1"; local mode="${2:-$REALIGN_AFTER_MODE}"; local -a mode_args
    case "$mode" in
        reextract) mode_args=(--reextract --refeaturize) ;;
        *)         mode_args=(--shift-spk --refeaturize) ;;
    esac
    echo "== fiber-realign  (post-step Klusters re-roll of .${tag:-base} groups; mode=$mode) =="
    _run fiber-realign "$SESS" "$ELEC" \
        --clu "$(clu_path "$tag")" \
        --align-method klusters "${mode_args[@]}" \
        --no-emit-clu \
        --variants standard,stderiv
}

fiber_refine() {      # 3. split + fold gates + merge-back (optional warp recall/gate) -> .refine
    echo "== fiber-refine  ($(clu_path "${STEP_IN:-}") -> .${STEP_OUT:-refine}) =="
    local warp_args=()
    [ -n "$MERGE_WARP_RECALL" ] && warp_args+=(--merge-warp-recall "$MERGE_WARP_RECALL" --merge-amp-thr "$MERGE_AMP_THR")
    [ -n "$MERGE_WARP_THR" ]    && warp_args+=(--merge-warp-thr "$MERGE_WARP_THR")
    [ -n "$MERGE_WARP_RESID_THR" ] && warp_args+=(--merge-warp-resid-thr "$MERGE_WARP_RESID_THR")
    [ -n "$MERGE_WARP_RESID_THR_INT" ] && warp_args+=(--merge-warp-resid-thr-int "$MERGE_WARP_RESID_THR_INT")
    [ -n "$MERGE_WARP_RESID_THR_PYR" ] && warp_args+=(--merge-warp-resid-thr-pyr "$MERGE_WARP_RESID_THR_PYR")
    local rkk_args=()
    [ "$RKK_DELETE" = "0" ] && rkk_args+=(--no-rkk-delete)
    local dedup_args=()
    [ "$REFINE_DEDUP" = "1" ] && dedup_args+=(--dedup)      # default off: keep clu aligned to .res for round-trip
    local ab_args=()
    [ "$AB_RECLAIM" = "1" ] && ab_args+=(--ab-reclaim --ab-distinct "$AB_DISTINCT" --ab-abs "$AB_ABS" --ab-margin "$AB_MARGIN" --ab-min "$AB_MIN" --ab-sigcap "$AB_SIGCAP" --ab-jobs "$AB_JOBS")  # opt-in contamination reclaim
    _run fiber-refine "$SESS" "$ELEC" \
        --in-clu "$(clu_path "${STEP_IN:-}")" \
        --out-method stderiv --out-stage "${STEP_OUT:-refine}" \
        --large "$REFINE_LARGE" --min-group "$REFINE_MIN_GROUP" --drop-min "$REFINE_DROP_MIN" \
        --nudge-split --feature-align "$FEATURE_ALIGN" \
        --merge-min-sim "$REFINE_MERGE_MIN_SIM" --merge-budget "$REFINE_MERGE_BUDGET" \
        --split-min-corr "$REFINE_SPLIT_MIN_CORR" --split-var-mult "$SPLIT_VAR_MULT" \
        --dedup-stale "$DEDUP_STALE" \
        --fold-off-thr "$FOLD_OFF_THR" \
        --chunk-minutes "$REFINE_CHUNK_MINUTES" --chunk-jobs "$REFINE_CHUNK_JOBS" \
        "${warp_args[@]}" "${rkk_args[@]+"${rkk_args[@]}"}" "${dedup_args[@]+"${dedup_args[@]}"}" "${ab_args[@]+"${ab_args[@]}"}" "${STEP_ARGS[@]+"${STEP_ARGS[@]}"}" "$@"
}

fiber_peel() {        # 3b. footprint+refractory consolidation of refine fragments (IN-PLACE relabel on .refine)
    echo "== fiber-peel  (consolidate .${STEP_IN:-refine} fragments by footprint+refractory, in-place) =="
    _run fiber-peel "$SESS" "$ELEC" \
        --clu-method stderiv --clu-stage "${STEP_IN:-refine}" \
        --out-stage "${STEP_OUT:-${STEP_IN:-refine}}" \
        --foot-hi "$PEEL_FOOT_HI" --foot-lo "$PEEL_FOOT_LO" \
        --refrac-ms "$PEEL_REFRAC_MS" --refrac-thr "$PEEL_REFRAC_THR" \
        --refrac-min-exp "$PEEL_REFRAC_MIN_EXP" --refrac-censor-ms "$PEEL_REFRAC_CENSOR_MS" \
        --min-n "$PEEL_MIN_N" "${STEP_ARGS[@]+"${STEP_ARGS[@]}"}" "$@"
}

fiber_cpos() {        # 4. positions ON the refine clu, from the RAW/standard spk
    echo "== fiber-cpos  (on .${STEP_IN:-refine}, from raw .spk.${STEP_SPK:-standard}) =="
    _run fiber-cpos "$SESS" "$ELEC" \
        --clu-method stderiv --clu-stage "${STEP_IN:-refine}" \
        --spk-method "${STEP_SPK:-standard}" \
        --out-method stderiv --out-stage "${STEP_OUT:-refine}" "${STEP_ARGS[@]+"${STEP_ARGS[@]}"}" "$@"
}

fiber_intrachunk() {  # 5. within-chunk merge + emit .units.npz for linking
    echo "== fiber-intrachunk  (.${STEP_IN:-refine} -> .${STEP_OUT:-refine_intrachunk}) =="
    local backbone_args=()
    [ -n "$BACKBONE_STD_COS" ] && backbone_args+=(--backbone-std-cos "$BACKBONE_STD_COS")
    [ -n "$BACKBONE_WARP" ]    && backbone_args+=(--backbone-warp "$BACKBONE_WARP")
    _run fiber-intrachunk "$SESS" "$ELEC" \
        --clu-method stderiv --clu-stage "${STEP_IN:-refine}" \
        --cpos-method stderiv --cpos-stage "${STEP_CPOS:-${STEP_IN:-refine}}" \
        --profile recommended --emit-units \
        "${backbone_args[@]+"${backbone_args[@]}"}" \
        --out-stage "${STEP_OUT:-refine_intrachunk}" "${STEP_ARGS[@]+"${STEP_ARGS[@]}"}" "$@"
}

fiber_link() {        # 6. cross-chunk link -> .refine_linked
    echo "== fiber-link  (.${STEP_IN:-refine} + .${STEP_UNITS:-refine_intrachunk}.units -> .${STEP_OUT:-refine_linked}) =="
    local units="$(clu_path "${STEP_UNITS:-refine_intrachunk}").units.npz"
    local warp_args=()
    [ -n "$LINK_WARP_THR" ] && warp_args+=(--warp-thr "$LINK_WARP_THR")
    [ -n "$LINK_WARP_AMP_THR" ] && warp_args+=(--warp-amp-thr "$LINK_WARP_AMP_THR")
    [ -n "$LINK_WARP_RESID_THR" ] && warp_args+=(--warp-resid-thr "$LINK_WARP_RESID_THR")
    [ -n "$LINK_CFIBER_Q" ] && warp_args+=(--cfiber-q "$LINK_CFIBER_Q")
    [ -n "$LINK_TAN_THR" ] && warp_args+=(--tan-thr "$LINK_TAN_THR")
    local bundle_args=()
    if [ -n "$LINK_BUNDLE" ] && [ "$LINK_BUNDLE" != chunkexcl ]; then
        bundle_args+=(--bundle "$LINK_BUNDLE" --var-scale "$LINK_VAR_SCALE" --n-pc "$LINK_N_PC")
        [ -n "$LINK_VAR_ALLOW" ] && bundle_args+=(--var-allow "$LINK_VAR_ALLOW")
    fi
    local dr_args=()
    if [ "$LINK_DR_CANDIDATES" = 1 ]; then
        dr_args+=(--dr-candidates --dr-k "$LINK_DR_K")
        [ -n "$LINK_DR_THR" ] && dr_args+=(--dr-thr "$LINK_DR_THR")
    fi
    _run fiber-link "$SESS" "$ELEC" \
        --clu-method stderiv --clu-stage "${STEP_IN:-refine}" \
        --cpos-method stderiv --cpos-stage "${STEP_CPOS:-${STEP_IN:-refine}}" \
        --from-units "$units" \
        --cos-thr "$LINK_COS_THR" --pos-thr "$LINK_POS_THR" --off-thr "$LINK_OFF_THR" --max-gap "$LINK_MAX_GAP" \
        --amp-gate "$LINK_AMP_GATE" --min-a "$LINK_MIN_A" --amp-span "$LINK_AMP_SPAN" \
        --align-lag "$LINK_ALIGN_LAG" --align-upsample "$LINK_ALIGN_UPSAMPLE" --primary-amp-frac "$LINK_PRIMARY_AMP_FRAC" \
        --refine-trajectory \
        "${warp_args[@]}" "${bundle_args[@]}" "${dr_args[@]}" \
        --out-stage "${STEP_OUT:-refine_linked}" "${STEP_ARGS[@]+"${STEP_ARGS[@]}"}" "$@"
    echo "[done] linked clu: $(clu_path "${STEP_OUT:-refine_linked}")"
}

fiber_refit() {       # post-curation: rebuild the per-unit/per-chunk model from a CURATED clu (no regrouping)
    echo "== fiber-refit  (curated .${STEP_IN:-curated} + cpos .${STEP_CPOS:-${STEP_IN:-curated}} -> .${STEP_OUT:-${STEP_IN:-curated}_refit}.units) =="
    _run fiber-refit "$SESS" "$ELEC" \
        --clu-method stderiv --clu-stage "${STEP_IN:-curated}" \
        --cpos-method stderiv --cpos-stage "${STEP_CPOS:-${STEP_IN:-curated}}" \
        --out-stage "${STEP_OUT:-${STEP_IN:-curated}_refit}" "${STEP_ARGS[@]+"${STEP_ARGS[@]}"}" "$@"
}

# ----------------------------- dispatcher -----------------------------------
usage() {
    echo "usage: $(basename "$0") <elec> [all | <stage> ...]"
    echo "       $(basename "$0") <elec> <stage> [<arg> ...]   # one stage; args after it override pipeline defaults"
    echo "       $(basename "$0") <elec> --plan <plan.yaml>     # run a custom, reorderable, repeatable step plan"
    echo "       $(basename "$0") --emit-plan > plan.yaml        # write the canonical plan as an editable template"
    echo "options: --plan <file>  run an ordered step plan (stages may repeat with different in/out tags+params)"
    echo "         --dry-run | -n  print the stage commands instead of running them (works with or without --plan)"
    echo "         --emit-plan     print the canonical plan template ; -l/--list  list stages ; -h/--help"
    echo "primary plan: a 'pipeline:' section embedded in fiber-kit.yaml (\$FK_CONFIG) runs by default ONLY when no --plan"
    echo "              and no stage is named (bare '<elec>' or '<elec> all'); naming stage(s) runs just those."
    echo "stages (canonical order): ${STAGES[*]}"
    echo "curated stages (run explicitly / in a plan, not in 'all'): ${CURATED_STAGES[*]}"
    echo "override example: $(basename "$0") 5 fiber-intrachunk --gate cosine --amp-gate 1.3"
    echo "config via env: FK_DIR (default \$PWD), FK_SESS (default basename); <elec> is the first arg (or FK_ELEC)"
}

fiber_backbone_link() {   # link fiber-session fragments on the invariant backbone -> .backbone_linked
    # Reads the fiber-session .clu + the standard .spk directly (does its own realign + templating), so it
    # needs NO fiber-refine / fiber-intrachunk / fiber-cpos.  FK_BBLINK_* knobs come from $FK_CONFIG / the
    # exported env; per-step plan `params:` (e.g. channels, min-snr-q) override via argparse last-wins.
    echo "== fiber-backbone-link  (.${STEP_IN:-fiber_session} -> .${STEP_OUT:-backbone_linked}) =="
    _run fiber-backbone-link "$SESS" "$ELEC" \
        --clu-method stderiv --clu-stage "${STEP_IN:-fiber_session}" \
        --out-tag "${STEP_OUT:-backbone_linked}" \
        "${STEP_ARGS[@]+"${STEP_ARGS[@]}"}" "$@"
}

fiber_xcorr_merge() {   # merge clusters by Klusters roll-shift cosine (realign after each merge) -> .xcorr_merged
    echo "== fiber-xcorr-merge  (.${STEP_IN:-backbone_linked} -> .${STEP_OUT:-xcorr_merged}) =="
    _run fiber-xcorr-merge "$SESS" "$ELEC" --clu-method stderiv --clu-stage "${STEP_IN:-backbone_linked}" --out-tag "${STEP_OUT:-xcorr_merged}" "${STEP_ARGS[@]+"${STEP_ARGS[@]}"}" "$@"
}

run_stage() {
    # forward the command-line override args (set in main) to the selected stage only; argparse is
    # last-wins, so a forwarded --flag overrides the pipeline default of the same flag.
    local -a ov=()
    [ "$1" = "${OVERRIDE_STAGE:-}" ] && ov=("${OVERRIDE_ARGS[@]}")
    case "$1" in
        fiber-session)    fiber_session    "${ov[@]}" ;;
        fiber-realign)    fiber_realign    "${ov[@]}" ;;
        fiber-refine)     fiber_refine     "${ov[@]}" ;;
        fiber-peel)       fiber_peel       "${ov[@]}" ;;

        fiber-cpos)       fiber_cpos       "${ov[@]}" ;;
        fiber-intrachunk) fiber_intrachunk "${ov[@]}" ;;
        fiber-link)       fiber_link       "${ov[@]}" ;;
        fiber-refit)      fiber_refit      "${ov[@]}" ;;
        fiber-backbone-link) fiber_backbone_link "${ov[@]}" ;;
        fiber-xcorr-merge) fiber_xcorr_merge "${ov[@]}" ;;
        fiber-stochastic) fiber_stochastic "${ov[@]}" ;;
        *) echo "unknown stage: $1" >&2; usage >&2; exit 2 ;;
    esac
}

run_plan_stage() {     # dispatch a plan step (STEP_* already set in the calling subshell)
    case "$1" in
        fiber-session)    fiber_session    ;;
        fiber-realign)    fiber_realign    ;;
        fiber-refine)     fiber_refine     ;;
        fiber-peel)       fiber_peel       ;;

        fiber-cpos)       fiber_cpos       ;;
        fiber-intrachunk) fiber_intrachunk ;;
        fiber-link)       fiber_link       ;;
        fiber-stochastic) fiber_stochastic ;;
        fiber-refit)      fiber_refit      ;;
        fiber-backbone-link) fiber_backbone_link ;;
        fiber-xcorr-merge) fiber_xcorr_merge ;;
        *) echo "unknown stage in plan: $1" >&2; exit 2 ;;
    esac
}

# Parse a plan YAML into TAB-delimited normalised steps: stage<TAB>in<TAB>out<TAB>units<TAB>spk<TAB>cpos<TAB>argsquoted
_plan_parse() {
    python3 - "$1" <<'PYPLAN'
import sys, shlex
try:
    import yaml
except ImportError:
    sys.stderr.write("fiber-pipeline: --plan needs PyYAML (pip install pyyaml)\n"); sys.exit(3)
try:
    doc = yaml.safe_load(open(sys.argv[1])) or {}
except Exception as e:
    sys.stderr.write("fiber-pipeline: cannot read plan %s: %s\n" % (sys.argv[1], e)); sys.exit(1)
steps = doc.get("pipeline") if isinstance(doc, dict) else doc
if not isinstance(steps, list) or not steps:
    sys.stderr.write("fiber-pipeline: plan has no 'pipeline:' list of steps\n"); sys.exit(1)
KNOWN = {"fiber-session", "fiber-realign", "fiber-refine", "fiber-peel", "fiber-cpos", "fiber-intrachunk", "fiber-link", "fiber-refit", "fiber-backbone-link", "fiber-xcorr-merge"}
def field(st, k):
    v = st.get(k, "")
    return "" if v is None else str(v)
rows = []
for i, st in enumerate(steps):
    if not isinstance(st, dict):
        sys.stderr.write("fiber-pipeline: plan step %d is not a mapping\n" % i); sys.exit(1)
    stage = st.get("stage")
    if stage not in KNOWN:
        sys.stderr.write("fiber-pipeline: plan step %d: unknown stage %r (known: %s)\n"
                         % (i, stage, ", ".join(sorted(KNOWN)))); sys.exit(1)
    args = []
    params = st.get("params") or {}
    if isinstance(params, dict):
        for k, v in params.items():
            flag = "--" + str(k).replace("_", "-").lstrip("-")
            if v is True or v is None or v == "":
                args.append(flag)                       # bare/boolean flag
            else:
                args += [flag, str(v)]
    extra = st.get("args") or []
    if isinstance(extra, list):
        args += [str(a) for a in extra]
    argq = " ".join(shlex.quote(a) for a in args)
    rows.append("\x1f".join([stage, field(st, "in"), field(st, "out"),
                           field(st, "units"), field(st, "spk"), field(st, "cpos"), argq]))
sys.stdout.write("\n".join(rows))
PYPLAN
}

run_plan() {           # run an ordered, possibly-repeating plan of steps
    local plan="$1"
    [ -f "$plan" ] || { echo "fiber-pipeline: plan not found: $plan" >&2; exit 2; }
    local spec; spec="$(_plan_parse "$plan")" || exit $?
    # Track the most recent fiber-intrachunk out-stage so a later fiber-link can
    # default its --from-units producer (<stage>.units.npz) to the stage the
    # units were actually emitted at when the plan step omits 'units'.  Without
    # this the default is the canonical 'refine_intrachunk', which is wrong for
    # any plan whose intrachunk writes a different stage (e.g. exp_chunk) and
    # makes link abort with a missing <stage>.units.npz.
    local n=0 st pin pout punits pspk pcpos pargs
    local last_intrachunk_out=refine_intrachunk
    while IFS=$'\x1f' read -r st pin pout punits pspk pcpos pargs; do
        [ -z "$st" ] && continue
        n=$((n + 1))
        printf '== [plan %d] %s ==\n' "$n" "$st"
        [ "$st" = fiber-intrachunk ] && last_intrachunk_out="${pout:-refine_intrachunk}"
        (   # subshell: STEP_* and STEP_ARGS are local to this step (no leak between steps)
            STEP_IN="$pin"; STEP_OUT="$pout"; STEP_UNITS="${punits:-$last_intrachunk_out}"; STEP_SPK="$pspk"; STEP_CPOS="$pcpos"
            eval "STEP_ARGS=( $pargs )"
            run_plan_stage "$st"
        )
    done <<EOF
$spec
EOF
    [ "$n" -gt 0 ] || { echo "fiber-pipeline: plan produced no steps" >&2; exit 1; }
}

emit_plan() {          # print the canonical pipeline as an editable plan template
    cat <<'YAML'
# fiber-kit pipeline plan.  Steps run IN THIS ORDER; the same stage may appear more than once with
# different in/out tags and params.  'in'/'out'/'units'/'cpos' are clu STAGE tags ('' = the base
# over-cluster .clu.stderiv.<elec>).  'params' become --flag value (underscores -> dashes); 'args'
# are appended verbatim.  Run with:   fiber-pipeline <elec> --plan thisfile.yaml   (add --dry-run to preview).
pipeline:
  - {stage: fiber-session,    out: ""}
  - {stage: fiber-realign,    in: ""}
  - {stage: fiber-refine,     in: "",      out: refine}
  - {stage: fiber-cpos,       in: refine,  out: refine, spk: standard}
  - {stage: fiber-intrachunk, in: refine,  out: refine_intrachunk}
  - {stage: fiber-link,       in: refine,  units: refine_intrachunk, out: refine_linked}

# Example -- run refine TWICE (coarse pass, then a finer pass) and link off the second:
#   - {stage: fiber-refine,     in: "",       out: refine,   params: {large: 150}}
#   - {stage: fiber-refine,     in: refine,   out: refine2,  params: {large: 80, merge-min-sim: 0.94}}
#   - {stage: fiber-cpos,       in: refine2,  out: refine2}
#   - {stage: fiber-intrachunk, in: refine2,  out: refine2_intrachunk}
#   - {stage: fiber-link,       in: refine2,  units: refine2_intrachunk, out: refine2_linked}
YAML
}

main() {
    # help/list/emit-plan need no config
    case "${1:-}" in
        -h|--help) usage; exit 0 ;;
        -l|--list) list_stages; exit 0 ;;
        --emit-plan) emit_plan; exit 0 ;;
    esac

    # option scan: pull --dry-run/-n and --plan out of the argument list (anywhere), keep the rest positional
    local PLAN=""
    local -a pos=()
    while [ "$#" -gt 0 ]; do
        case "$1" in
            -n|--dry-run)  FK_DRYRUN=1; export FK_DRYRUN; shift ;;
            --emit-plan)   emit_plan; exit 0 ;;
            --plan)        PLAN="${2:-}"; [ -n "$PLAN" ] || { echo "error: --plan needs a file" >&2; exit 2; }; shift 2 ;;
            --plan=*)      PLAN="${1#--plan=}"; shift ;;
            *)             pos+=("$1"); shift ;;
        esac
    done
    set -- "${pos[@]+"${pos[@]}"}"

    # electrode group: first positional if numeric, else FK_ELEC fallback
    local ELEC
    if [[ "${1:-}" =~ ^[0-9]+$ ]]; then
        ELEC="$1"; shift
    else
        ELEC="${FK_ELEC:-}"
    fi
    [ -n "$ELEC" ] || {
        echo "error: electrode group required as the first argument (e.g. '$(basename "$0") 5'), or set FK_ELEC" >&2
        usage >&2; exit 2
    }

    # build the requested stage set, then optional per-stage override args (BEFORE any cd, so bad
    # names report cleanly).  The first token after the stage name(s) that is NOT a stage name begins
    # override args, passed through to fiber-<stage> -- only when exactly one stage is selected.
    # (Skipped in --plan mode: the plan file defines the steps and their per-step params.)
    declare -A want=()
    local OVERRIDE_STAGE=""
    local -a OVERRIDE_ARGS=()
    local REQUESTED_STAGES=0        # 1 = the user named specific stage(s) -> run those, NOT the embedded plan
    if [ -z "$PLAN" ]; then
      if [ "$#" -eq 0 ] || [ "${1:-}" = "all" ]; then
        for s in "${STAGES[@]}"; do want[$s]=1; done
      else
        REQUESTED_STAGES=1          # explicit stage(s) named -> single/selected-stage run overrides the embedded plan
        local in_ov=0
        for a in "$@"; do
            if [ "$in_ov" = 0 ]; then
                local ok=0; for s in "${KNOWN_STAGES[@]}"; do [ "$a" = "$s" ] && ok=1; done
                if [ "$ok" = 1 ]; then want[$a]=1; else in_ov=1; OVERRIDE_ARGS+=("$a"); fi
            else
                OVERRIDE_ARGS+=("$a")
            fi
        done
        if [ "${#OVERRIDE_ARGS[@]}" -gt 0 ]; then
            [ "${#want[@]}" -eq 1 ] || {
                echo "error: override args (${OVERRIDE_ARGS[*]}) must follow exactly one stage; got ${#want[@]}" >&2
                echo "       e.g. $(basename "$0") $ELEC fiber-intrachunk --gate cosine --amp-gate 1.3" >&2
                usage >&2; exit 2
            }
            for s in "${!want[@]}"; do OVERRIDE_STAGE="$s"; done
        fi
      fi
    fi

    # resolve session config
    local DIR SESS
    DIR="${FK_DIR:-$PWD}"
    SESS="${FK_SESS:-$(basename "$DIR")}"
    [ -d "$DIR" ]  || { echo "error: session dir not found: $DIR (set FK_DIR)" >&2; exit 2; }
    cd "$DIR"

    # --plan: run the ordered (possibly-repeating) plan and stop.  With no --plan, an embedded
    # `pipeline:` section in $FK_CONFIG (fiber-kit.yaml) is the PRIMARY plan and runs by default.
    if [ -z "$PLAN" ] && [ "$REQUESTED_STAGES" = 0 ] && [ -f "$FK_CONFIG" ] && grep -qE '^pipeline:[[:space:]]*$' "$FK_CONFIG"; then
        PLAN="$FK_CONFIG"
        echo "fiber-pipeline: running the primary plan embedded in $FK_CONFIG (no --plan / no stage named)" >&2
    fi
    if [ -n "$PLAN" ]; then
        run_plan "$PLAN"
        return
    fi

    # the LAST stage that both runs and triggers a post-step realign gets the final (re-extract) treatment,
    # so the artefacts handed to curation are a clean .fil re-extraction; earlier ones stay fast (shift-spk).
    local final_realign=""
    for s in "${KNOWN_STAGES[@]}"; do
        [ -n "${want[$s]:-}" ] || continue
        case " $REALIGN_AFTER " in *" $s "*) final_realign="$s" ;; esac
    done

    # run in canonical order (curated stages last); only those in `want` actually run
    for s in "${KNOWN_STAGES[@]}"; do
        if [ -n "${want[$s]:-}" ]; then
            run_stage "$s"
            case " $REALIGN_AFTER " in                 # Klusters re-roll spikes into their new groups after the step
                *" $s "*)
                    if [ "$s" = "$final_realign" ]; then
                        realign_after "$(stage_out_tag "$s")" "$REALIGN_FINAL_MODE"
                    else
                        realign_after "$(stage_out_tag "$s")" "$REALIGN_AFTER_MODE"
                    fi
                    ;;
            esac
        fi
    done
}

main "$@"
