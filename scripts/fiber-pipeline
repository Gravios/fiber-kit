#!/usr/bin/env bash
# ============================================================================
# fiber-kit pipeline driver, one electrode group, stage-dispatched.
# Installed on PATH by `pip install fiber-kit` (setup.cfg [options] scripts).
#
# USAGE:
#   fiber-pipeline <elec>                        # whole pipeline, in canonical order
#   fiber-pipeline <elec> all                    # same
#   fiber-pipeline <elec> fiber-refine           # one stage
#   fiber-pipeline <elec> fiber-cpos fiber-link  # several (always run in canonical order)
#   fiber-pipeline -l | --list                   # list stages
#
# The electrode group is the FIRST positional argument.  (FK_ELEC is still honoured
# as a fallback when no leading group is given, for older invocations.)
#
# CONFIG (env-overridable; the installed script is not meant to be hand-edited):
#   FK_DIR    session directory                 (default: current directory)
#   FK_SESS   session name                      (default: basename of FK_DIR)
#   FK_ELEC   electrode group fallback          (used only if no leading <elec> arg)
#   plus the algorithm/warp knobs below (each FK_*-overridable).
# e.g.:  fiber-pipeline 5 fiber-refine
#        cd /data/.../sirotaA-jg-000005-20120312 && fiber-pipeline 5
#
# Each stage reads the previous stage's output, so a single-stage run assumes the
# upstream artefacts already exist.  Canonical order:
#   fiber-session -> fiber-realign -> fiber-refine -> fiber-cpos -> fiber-intrachunk -> fiber-link
#
# Correctness notes baked in (do not "fix"):
#   * fiber-session uses --fine-method for the algorithm (--method is the feature tag).
#   * fiber-realign runs as an IN-PLACE commit: NO --out-variant (it reads the INPUT .spk
#     from that variant, so --out-variant realign would seek .spk.realign.N and fail).
#   * fiber-cpos localizes from the RAW/standard .spk, never .spkD, and runs AFTER refine
#     on the refine clu so positions key to the clu the merge tools read.
#
# Warp knobs (group-delay / Omlor-Giese) require patches 0083-0086; they are passed only
# when non-empty, so the script still runs on a tree without them.  Empty = disabled.
# ============================================================================
set -euo pipefail

# ---------- optional YAML config (sets the FK_* knobs the block below reads) --------------
# fiber-kit.yaml is a FLAT <FK_KEY: value> mapping of tuning knobs.  Run `fiber-kit-init` to
# drop a template into the current directory, then edit it.  Precedence:
#     exported FK_* env var   >   $FK_CONFIG yaml   >   built-in default in the block below.
# Absent file => built-in defaults (identical to the pre-config behaviour).  An empty YAML value
# ("") means "use the built-in default".  $FK_CONFIG defaults to fiber-kit.yaml in the current
# working directory (where the pipeline is run); set FK_CONFIG to point elsewhere.
FK_CONFIG="${FK_CONFIG:-$PWD/fiber-kit.yaml}"
if [ -f "$FK_CONFIG" ]; then
    _cfg="$(python3 - "$FK_CONFIG" <<'PYCFG'
import sys, shlex
try:
    import yaml
except ImportError:
    sys.stderr.write("fiber-pipeline: PyYAML not installed; ignoring %s\n" % sys.argv[1]); sys.exit(0)
try:
    with open(sys.argv[1]) as fh:
        d = yaml.safe_load(fh) or {}
except Exception as e:
    sys.stderr.write("fiber-pipeline: cannot read %s: %s\n" % (sys.argv[1], e)); sys.exit(1)
if not isinstance(d, dict):
    sys.stderr.write("fiber-pipeline: %s is not a flat key:value mapping\n" % sys.argv[1]); sys.exit(1)
for k, v in d.items():
    if not (isinstance(k, str) and k.startswith("FK_") and k.replace("_", "").isalnum()):
        sys.stderr.write("fiber-pipeline: skipping non-FK_/odd key %r\n" % (k,)); continue
    if isinstance(v, bool):            v = "1" if v else "0"
    elif v is None:                    v = ""
    elif isinstance(v, (int, float, str)): v = str(v)
    else:
        sys.stderr.write("fiber-pipeline: skipping non-scalar %s\n" % k); continue
    # assign ONLY if the FK_* env var is UNSET, so an exported override (even empty) still wins;
    # shlex.quote keeps empty -> '' (a true empty string, not the literal two-char ''):
    print('if [ -z "${%s+x}" ]; then %s=%s; export %s; fi' % (k, k, shlex.quote(v), k))
PYCFG
)" || { echo "fiber-pipeline: failed to parse $FK_CONFIG" >&2; exit 1; }
    eval "$_cfg"
fi

# ===================== algorithm knobs (all env-overridable) ===========
CFIBER_Q="${FK_CFIBER_Q:-0.90}"          # 0079 fiber-session : within-fiber cfiber-null quantile (shape veto)
FOLD_OFF_THR="${FK_FOLD_OFF_THR:-0.22}"  # 0078 fiber-refine  : timing veto on the contaminant fold (0.20-0.25)
SPLIT_VAR_MULT="${FK_SPLIT_VAR_MULT:-1.5}" # 0081 fiber-refine : split only clusters w/ top-3 feat-var > x median
# fiber-intrachunk tuning now lives in the per-session <session>.yaml `fiber_kit.intrachunk` section
# (config.py IntrachunkConfig).  The pipeline passes `--profile recommended` (the tuned baseline);
# that block, an exported FK_INTRA_*/FK_ALIGN_*/FK_REFRAC_CEILING/FK_PRE_MERGE_COS/FK_CFIBER_* env
# var, or a direct --flag override it.  `fiber-kit-session-config` emits a starter block.
DEDUP_STRICT="${FK_DEDUP_STRICT:-1}"     # fiber-refine: 1=ERROR if a dedup leaves a live per-spike file misaligned (stale); 0=skip+continue

# ===================== warp knobs 0083-0086 (empty = off) ==============
# 0086 fiber-refine recall: merge drift fragments cosine misses, when median-template group-delay
# (warp) AND amplitude-profile both agree.  g5: warp>=0.9 & amp>=0.7 recovered 323/395 such merges
# at >=0.976 precision, refractory-clean.  Aggressive -- calibrate vs fuller curation before production.
MERGE_WARP_RECALL="${FK_MERGE_WARP_RECALL:-0.9}"   # empty disables the recall path
MERGE_AMP_THR="${FK_MERGE_AMP_THR:-0.7}"           # amplitude-profile correlation floor for the recall path
MERGE_WARP_THR="${FK_MERGE_WARP_THR:-}"            # 0084 precision GATE on cosine-selected merges (empty=off)
# 0085 fiber-link warp co-gate: on g5 did NOT help (precision already saturated; per-chunk templates
# too noisy) -- off by default.  The linking win was relaxing the cosine prefilter (LINK_COS_THR).
LINK_WARP_THR="${FK_LINK_WARP_THR:-}"              # empty = off
LINK_COS_THR="${FK_LINK_COS_THR:-0.75}"            # 0.75 added 7 clean bundles vs the 0.85 default

# ===================== cfiber shape gate (affine-invariant) ============
# cfiber = rotation+scale+translation-invariant Fourier descriptor of each unit's complex channel-
# loop.  Drift-invariant by construction, so it complements/strengthens the (mutual-centre-dependent)
# cosine shape term.  Real-data (g5 180-210, split-half): cfiber AUC ~0.955 vs cosine ~0.964 overall,
# but marginally BETTER on the hard look-alike subset (cosine>0.85: 0.867 vs 0.861) -- the regime that
# matters; its advantage is expected to widen under real cross-chunk drift (untested here).
#   * intrachunk: cfiber REPLACES the cosine shape term (gate='cfiber'); threshold self-calibrates from
#     the per-fragment split-half null at INTRA_CFIBER_Q.  Set FK_INTRA_GATE=cosine to revert.
#   * link: cfiber is an additional CO-GATE (cosine AND cfiber); threshold self-calibrates at link time
#     from the overlap-backbone same-unit shape distances at LINK_CFIBER_Q.  Empty disables it.
LINK_CFIBER_Q="${FK_LINK_CFIBER_Q:-0.90}"          # empty = link cfiber co-gate off
LINK_AMP_GATE="${FK_LINK_AMP_GATE:-0}"             # absolute log-amplitude gate (natural log; 0 = off)

# ===================== over-split tuning (small-cluster regime) ========
# Goal: more, CLEANER clusters that separate subtle co-located pairs (footprint-ratio /
# sub-sample timing), for the over-split -> fiber-intrachunk re-merge strategy.  These lower
# the SIZE gates and sharpen alignment/features while leaving the STATISTICAL accept gates
# (dip test, BIC) largely intact -- so splits track real structure, not noise.
# STARTING POINTS from code-reading + reasoning, NOT a validated sweep: check resulting cluster
# count / purity and back off if over-fragmenting (raise REFINE_LARGE / DIP_MIN, lower DIP_ALPHA).
REFINE_LARGE="${FK_REFINE_LARGE:-150}"             # refine splits only clusters >= this (stock 800 skips
                                                   #   every 60-700-spike unit -> subtle pairs never split)
REFINE_MIN_GROUP="${FK_REFINE_MIN_GROUP:-30}"      # min spikes per split piece in refine (stock 40)
REFINE_MERGE_MIN_SIM="${FK_REFINE_MERGE_MIN_SIM:-0.96}" # slacker merge-back (stock 0.92): keep over-splits
                                                   #   for fiber-intrachunk to adjudicate locally
DIP_DIM="${FK_DIP_DIM:-6}"                          # session dip-test PCA dims (stock 4): expose footprint PCs
DIP_ALPHA="${FK_DIP_ALPHA:-0.02}"                   # session dip p (stock 0.01): mildly more permissive; keep
                                                   #   statistical (>0.05 starts splitting on noise)
DIP_MIN="${FK_DIP_MIN:-30}"                         # session min cluster size to bisect (stock 40)
INCLUSION_K="${FK_INCLUSION_K:-2.5}"                # session per-fiber radius median+k*MAD (stock 3.0): purer cores
FEATURE_ALIGN="${FK_FEATURE_ALIGN:-xcorr}"          # sub-sample channel-summed align before featurize: the #1
                                                   #   lever for subtle shapes (misalignment blurs them together)
EBAND="${FK_EBAND:-0}"                              # session energy-band split (1=on): partition each ENERGY-
                                                   #   CONFOUNDED coarse fiber by log10-energy band, split per band,
                                                   #   relink by overlap-anchor -- surfaces shape sub-units the drift
                                                   #   axis masks (off by default; falls back to --fine-method per fiber)
EBAND_WIDTH="${FK_EBAND_WIDTH:-0.45}"              # band width (decades of energy)
EBAND_OVERLAP="${FK_EBAND_OVERLAP:-0.2}"           # band overlap (decades) for the overlap-anchor link
EBAND_CONFOUND="${FK_EBAND_CONFOUND:-0.4}"         # band a fiber only if PC1 R^2 vs log-energy >= this
EBAND_MIN_SPAN="${FK_EBAND_MIN_SPAN:-0.6}"         # band a fiber only if it spans >= this many decades
EBAND_LOW_ASSIGN="${FK_EBAND_LOW_ASSIGN:-0}"       # bottom fraction of the energy range made ASSIGNMENT-ONLY
                                                   #   (noise-floor angle): assign those spikes from the bands above

# ===================== stage gates (previously hardcoded, now exposed) ==
SESSION_FINE_METHOD="${FK_SESSION_FINE_METHOD:-rkk}"      # fiber-session per-fiber fine clusterer
SESSION_CHUNK_MIN="${FK_SESSION_CHUNK_MIN:-12}"           # fiber-session chunk length (min)
SESSION_MERGE_METHOD="${FK_SESSION_MERGE_METHOD:-sliding}" # fiber-session coarse merge method
SESSION_MERGE_CORR="${FK_SESSION_MERGE_CORR:-0.90}"       # fiber-session coarse merge correlation
REFINE_SPLIT_MIN_CORR="${FK_REFINE_SPLIT_MIN_CORR:-0.93}" # fiber-refine min split-piece corr to keep a split
REFINE_CHUNK_MINUTES="${FK_REFINE_CHUNK_MINUTES:-12}"     # fiber-refine chunk length (min)
LINK_POS_THR="${FK_LINK_POS_THR:-1.5}"                    # fiber-link position gate
LINK_OFF_THR="${FK_LINK_OFF_THR:-1.0}"                    # fiber-link inter-channel offset gate
LINK_MAX_GAP="${FK_LINK_MAX_GAP:-2}"                      # fiber-link max chunk gap to bridge

# ============================================================================
STAGES=(fiber-session fiber-realign fiber-refine fiber-cpos fiber-intrachunk fiber-link)

# ------------------------------- stages -------------------------------------
fiber_session() {     # 1. initial over-clustering -> <SESS>.clu.stderiv.<ELEC> (+ .spk.stderiv)
    echo "== [1/6] fiber-session =="
    local eband_args=()
    [ "$EBAND" = "1" ] && eband_args+=(--energy-band --eband-width "$EBAND_WIDTH" --eband-overlap "$EBAND_OVERLAP" --eband-confound "$EBAND_CONFOUND" --eband-min-span "$EBAND_MIN_SPAN" --eband-low-assign "$EBAND_LOW_ASSIGN")
    fiber-session "$SESS" "$ELEC" \
        --method stderiv --fine-method "$SESSION_FINE_METHOD" \
        --chunk-min "$SESSION_CHUNK_MIN" --merge-method "$SESSION_MERGE_METHOD" --merge-corr "$SESSION_MERGE_CORR" \
        --cfiber-gate --cfiber-q "$CFIBER_Q" \
        --feature-align "$FEATURE_ALIGN" --inclusion-k "$INCLUSION_K" \
        --dipsplit --dip-dim "$DIP_DIM" --dip-alpha "$DIP_ALPHA" --dip-min "$DIP_MIN" \
        "${eband_args[@]}"
}

fiber_realign() {     # 2. Klusters-style per-spike align, in-place commit (re-extract raw+stderiv from .fil)
    echo "== [2/6] fiber-realign (in-place commit) =="
    fiber-realign "$SESS" "$ELEC" \
        --clu "$SESS.clu.stderiv.$ELEC" \
        --align-method klusters --reextract --refeaturize \
        --variants standard,stderiv
}

fiber_refine() {      # 3. split + fold gates + merge-back (optional warp recall/gate) -> .refine
    echo "== [3/6] fiber-refine =="
    local warp_args=()
    [ -n "$MERGE_WARP_RECALL" ] && warp_args+=(--merge-warp-recall "$MERGE_WARP_RECALL" --merge-amp-thr "$MERGE_AMP_THR")
    [ -n "$MERGE_WARP_THR" ]    && warp_args+=(--merge-warp-thr "$MERGE_WARP_THR")
    fiber-refine "$SESS" "$ELEC" \
        --in-clu "$SESS.clu.stderiv.$ELEC" \
        --out-method stderiv --out-stage refine \
        --large "$REFINE_LARGE" --min-group "$REFINE_MIN_GROUP" \
        --nudge-split --feature-align "$FEATURE_ALIGN" \
        --merge-min-sim "$REFINE_MERGE_MIN_SIM" \
        --split-min-corr "$REFINE_SPLIT_MIN_CORR" --split-var-mult "$SPLIT_VAR_MULT" \
        $( [ "$DEDUP_STRICT" = "1" ] && echo --dedup-strict || echo --no-dedup-strict ) \
        --fold-off-thr "$FOLD_OFF_THR" \
        --chunk-minutes "$REFINE_CHUNK_MINUTES" \
        "${warp_args[@]}"
}

fiber_cpos() {        # 4. positions ON the refine clu, from the RAW/standard spk
    echo "== [4/6] fiber-cpos (on refine clu) =="
    fiber-cpos "$SESS" "$ELEC" \
        --clu-method stderiv --clu-stage refine \
        --spk-method standard \
        --out-method stderiv --out-stage refine
}

fiber_intrachunk() {  # 5. within-chunk merge + emit .units.npz for linking
    echo "== [5/6] fiber-intrachunk =="
    fiber-intrachunk "$SESS" "$ELEC" \
        --clu-method stderiv --clu-stage refine \
        --cpos-method stderiv --cpos-stage refine \
        --profile recommended --emit-units \
        --out-stage refine_intrachunk
}

fiber_link() {        # 6. cross-chunk link -> .refine_linked
    echo "== [6/6] fiber-link =="
    local units="$SESS.clu.stderiv.$ELEC.refine_intrachunk.units.npz"
    local warp_args=()
    [ -n "$LINK_WARP_THR" ] && warp_args+=(--warp-thr "$LINK_WARP_THR")
    [ -n "$LINK_CFIBER_Q" ] && warp_args+=(--cfiber-q "$LINK_CFIBER_Q")
    fiber-link "$SESS" "$ELEC" \
        --clu-method stderiv --clu-stage refine \
        --cpos-method stderiv --cpos-stage refine \
        --from-units "$units" \
        --cos-thr "$LINK_COS_THR" --pos-thr "$LINK_POS_THR" --off-thr "$LINK_OFF_THR" --max-gap "$LINK_MAX_GAP" \
        --amp-gate "$LINK_AMP_GATE" \
        --refine-trajectory \
        "${warp_args[@]}" \
        --out-stage refine_linked
    echo "[done] linked clu: $SESS.clu.stderiv.$ELEC.refine_linked"
}

# ----------------------------- dispatcher -----------------------------------
usage() {
    echo "usage: $(basename "$0") <elec> [all | <stage> ...]"
    echo "stages (canonical order): ${STAGES[*]}"
    echo "config via env: FK_DIR (default \$PWD), FK_SESS (default basename); <elec> is the first arg (or FK_ELEC)"
}

run_stage() {
    case "$1" in
        fiber-session)    fiber_session    ;;
        fiber-realign)    fiber_realign    ;;
        fiber-refine)     fiber_refine     ;;
        fiber-cpos)       fiber_cpos       ;;
        fiber-intrachunk) fiber_intrachunk ;;
        fiber-link)       fiber_link       ;;
        *) echo "unknown stage: $1" >&2; usage >&2; exit 2 ;;
    esac
}

main() {
    # help/list need no config
    case "${1:-}" in
        -h|--help) usage; exit 0 ;;
        -l|--list) printf '%s\n' "${STAGES[@]}"; exit 0 ;;
    esac

    # electrode group: first positional if numeric, else FK_ELEC fallback
    local ELEC
    if [[ "${1:-}" =~ ^[0-9]+$ ]]; then
        ELEC="$1"; shift
    else
        ELEC="${FK_ELEC:-}"
    fi
    [ -n "$ELEC" ] || {
        echo "error: electrode group required as the first argument (e.g. '$(basename "$0") 5'), or set FK_ELEC" >&2
        usage >&2; exit 2
    }

    # build + validate the requested stage set (BEFORE any cd, so bad names report cleanly)
    declare -A want=()
    if [ "$#" -eq 0 ] || [ "${1:-}" = "all" ]; then
        for s in "${STAGES[@]}"; do want[$s]=1; done
    else
        for a in "$@"; do
            local ok=0; for s in "${STAGES[@]}"; do [ "$a" = "$s" ] && ok=1; done
            [ "$ok" = 1 ] || { echo "unknown stage: $a" >&2; usage >&2; exit 2; }
            want[$a]=1
        done
    fi

    # resolve session config
    local DIR SESS
    DIR="${FK_DIR:-$PWD}"
    SESS="${FK_SESS:-$(basename "$DIR")}"
    [ -d "$DIR" ]  || { echo "error: session dir not found: $DIR (set FK_DIR)" >&2; exit 2; }
    cd "$DIR"

    # run in canonical order, regardless of the order requested
    for s in "${STAGES[@]}"; do
        if [ -n "${want[$s]:-}" ]; then run_stage "$s"; fi
    done
}

main "$@"
